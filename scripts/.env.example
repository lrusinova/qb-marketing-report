# Copy this file to .env and fill in your credentials.
# .env is git-ignored — never commit it.

# Your Quickbase Atlassian login email
JIRA_EMAIL=lrusinova@quickbase.com

# Jira API token — generate at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_TOKEN=your-jira-api-token-here

# Anthropic API key — for Claude Haiku hour estimation
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here
